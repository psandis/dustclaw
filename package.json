{
  "name": "dustclaw",
  "version": "0.1.0",
  "description": "Disk space monitoring, analysis, and cleanup CLI",
  "homepage": "https://github.com/psandis/dustclaw",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/psandis/dustclaw.git"
  },
  "bin": {
    "dustclaw": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets/dustclaw.png"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests"
  },
  "keywords": [
    "disk",
    "space",
    "cleanup",
    "monitor",
    "cli",
    "devtools"
  ],
  "author": "psandis <petri.sandholm@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
